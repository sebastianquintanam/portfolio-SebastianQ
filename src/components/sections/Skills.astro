---
import { skills } from '../../data/skills';
---

<section id="skills" class="py-20 border-t border-neutral-800 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-6">

    <p class="text-xs text-neutral-500 uppercase tracking-widest mb-3">Skills</p>
    <h2 class="text-2xl font-bold text-neutral-100 mb-12">Technical Skills</h2>

    <div class="space-y-10">
      {skills.map(({ category, skills: items }) => (
        <div>
          <p class="text-xs text-neutral-500 uppercase tracking-widest mb-4">{category}</p>
          <div class="flex flex-wrap items-start gap-3">
            {items.map((skill) =>
              skill.icon ? (
                <div class="skill-card icon-skill-card group flex flex-col items-center gap-2 w-20 sm:w-24 bg-neutral-900 border border-neutral-800 rounded-xl p-3 hover:border-neutral-600 hover:-translate-y-0.5 transition-all duration-300 cursor-default">
                  <img
                    src={skill.icon}
                    alt={skill.name}
                    width="36"
                    height="36"
                    class={skill.invertIcon
                      ? 'invert opacity-40 group-hover:opacity-100 transition-all duration-300'
                      : 'grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300'
                    }
                  />
                  <span class="text-xs text-neutral-500 group-hover:text-neutral-300 text-center leading-tight transition-colors duration-200">
                    {skill.name}
                  </span>
                </div>
              ) : (
                <div class="skill-card group flex items-center bg-neutral-900 border border-neutral-800 rounded-md px-3 py-1.5 hover:border-neutral-600 transition-all duration-300 cursor-default">
                  <span class="text-xs text-neutral-500 group-hover:text-neutral-300 transition-colors duration-200">
                    {skill.name}
                  </span>
                </div>
              )
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
