---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { site } from '../config/site';
---

<BaseLayout>
  <Header />
  <main class="max-w-5xl mx-auto px-6 pt-32 pb-16">
    <section id="hero">
      <p class="text-sm text-neutral-500 mb-2">{site.location}</p>
      <h1 class="text-4xl font-bold text-neutral-100 mb-3">{site.name}</h1>
      <p class="text-xl text-neutral-400 mb-6">{site.role}</p>
      <p class="max-w-xl text-neutral-400 leading-relaxed">{site.description}</p>
      <div class="flex gap-4 mt-8">
        <a
          href="#contact"
          class="px-5 py-2.5 bg-neutral-100 text-neutral-900 text-sm font-medium rounded-md hover:bg-white transition-colors"
        >
          Contacto
        </a>
        <a
          href="#projects"
          class="px-5 py-2.5 border border-neutral-700 text-neutral-300 text-sm font-medium rounded-md hover:border-neutral-500 hover:text-neutral-100 transition-colors"
        >
          Ver proyectos
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>