---
import { site } from '../../config/site';

const links = [
  {
    label: 'Email',
    href: `mailto:${site.email}`,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 6.5L2 7"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: site.linkedin,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4V9h4v1.5A6 6 0 0116 8zM2 9h4v12H2zm2-7a2 2 0 110 4 2 2 0 010-4z"/></svg>`,
  },
  {
    label: 'GitHub',
    href: site.github,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.757-1.333-1.757-1.089-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23a11.5 11.5 0 013-.405c1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
];
---

<section id="contact" class="py-24 border-t border-neutral-800 scroll-mt-24">
  <div class="max-w-5xl mx-auto px-6">

    <div class="flex items-center gap-2.5 mb-10">
      <span
        class="w-1.5 h-1.5 rounded-full bg-emerald-500 motion-safe:animate-pulse shrink-0"
        aria-hidden="true"
      ></span>
      <span class="text-sm text-neutral-400">Open to opportunities</span>
    </div>

    <h2 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight bg-gradient-to-br from-white via-neutral-100 to-neutral-400 bg-clip-text text-transparent leading-tight mb-6 max-w-3xl">
      Still building reliable systems.
    </h2>

    <p class="text-base sm:text-lg text-neutral-400 leading-relaxed max-w-xl mb-10">
      Backend systems, REST APIs, cloud infrastructure and security-aware architecture.
      Open to backend, cloud and software engineering opportunities.
    </p>

    <div class="flex flex-wrap gap-3 mb-8">
      <a
        href="/sebastian-quintana-cv.pdf"
        download
        class="flex items-center gap-2 px-5 py-3 bg-neutral-100 text-neutral-900 text-sm font-medium rounded-lg hover:bg-white hover:shadow-lg hover:shadow-white/10 transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download CV
      </a>

      {links.map(({ label, href, svg }) => (
        <a
          href={href}
          target={href.startsWith('mailto') ? undefined : '_blank'}
          rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class="group flex items-center gap-3 bg-neutral-900 border border-neutral-800 rounded-lg px-5 py-3 hover:border-neutral-600 hover:-translate-y-0.5 transition-all duration-200"
        >
          <span
            class="text-neutral-500 group-hover:text-neutral-300 transition-colors duration-200 shrink-0"
            set:html={svg}
          />
          <span class="text-sm font-medium text-neutral-300 group-hover:text-neutral-100 transition-colors duration-200">
            {label}
          </span>
          <span class="text-neutral-600 group-hover:text-neutral-400 group-hover:translate-x-0.5 transition-all duration-200">
            →
          </span>
        </a>
      ))}
    </div>

    <p class="text-xs text-neutral-600">
      {site.location} · Open to remote, hybrid and on-site opportunities
    </p>

  </div>
</section>
