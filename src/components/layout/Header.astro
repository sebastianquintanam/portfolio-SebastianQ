---
import { site } from '../../config/site';

const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Skills', href: '#skills', mobileHidden: true },
  { label: 'Projects', href: '#projects' },
  { label: 'Experience', href: '#experience', mobileHidden: true },
  { label: 'Contact', href: '#contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-neutral-950/80 backdrop-blur-sm border-b border-neutral-800">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-sm font-semibold tracking-wide text-neutral-100 hover:text-white transition-colors">
      {site.name}
    </a>
    <ul class="flex items-center gap-6">
      {navLinks.map(({ label, href, mobileHidden }) => (
        <li class:list={[mobileHidden && 'hidden sm:list-item']}>
          <a
            href={href}
            class="text-sm text-neutral-400 hover:text-neutral-100 transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
