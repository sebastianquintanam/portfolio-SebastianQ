---
import { site } from '../../config/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-800 mt-24">
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-neutral-500">
    <span>© {year} {site.name}</span>
    <div class="flex items-center gap-5">
      <a href={site.github} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-100 transition-colors">
        GitHub
      </a>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-100 transition-colors">
        LinkedIn
      </a>
      <a href={`mailto:${site.email}`} class="hover:text-neutral-100 transition-colors">
        Email
      </a>
    </div>
  </div>
</footer>
