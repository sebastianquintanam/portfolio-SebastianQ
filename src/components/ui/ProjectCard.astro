---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { title, type, description, tags, link, isBuilding, inProgress } = project;
---

<article
  class:list={[
    'group flex flex-col gap-4 rounded-xl p-6 bg-neutral-900 ring-1 ring-white/[0.05] ring-inset hover:-translate-y-0.5 transition-all duration-200',
    isBuilding
      ? 'border border-dashed border-neutral-700 hover:border-neutral-500'
      : 'border border-neutral-800 hover:border-neutral-700',
  ]}
>
  <div class="flex items-center gap-2">
    {isBuilding && (
      <span class="w-1.5 h-1.5 shrink-0 rounded-full bg-neutral-400 animate-pulse" />
    )}
    <span class="text-xs text-neutral-500">{type}</span>
  </div>

  <div>
    <h3 class="text-base font-semibold text-neutral-100 mb-1">{title}</h3>
    {inProgress && !isBuilding && (
      <span class="text-xs text-neutral-600">In progress</span>
    )}
  </div>

  <p class="text-sm text-neutral-400 leading-relaxed">{description}</p>

  <div class="flex flex-wrap gap-2 mt-auto pt-1">
    {tags.map((tag) => (
      <span class="text-xs text-neutral-500 bg-neutral-900 border border-neutral-800 px-2.5 py-0.5 rounded-md">
        {tag}
      </span>
    ))}
  </div>

  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`View ${title} project`}
      class="text-xs text-neutral-400 hover:text-neutral-100 transition-colors self-start"
    >
      View →
    </a>
  )}
</article>
